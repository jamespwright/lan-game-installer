; Script generated by the Inno Setup Script Wizard.
; SEE THE DOCUMENTATION FOR DETAILS ON CREATING INNO SETUP SCRIPT FILES!
; Non-commercial use only

#define MyAppName "Battlefield 4"
#define MyAppVersion "1.0"
#define MyAppPublisher "DICE"
#define MyAppURL "https://www.DICE.com/"

[Setup]
; NOTE: The value of AppId uniquely identifies this application. Do not use the same AppId value in installers for other applications.
; (To generate a new GUID, click Tools | Generate GUID inside the IDE.)
AppId={{DAD7E1AD-A3D4-4AF1-90AB-52DDBDD7A116}
AppName={#MyAppName}
AppVersion={#MyAppVersion}
;AppVerName={#MyAppName} {#MyAppVersion}
AppPublisher={#MyAppPublisher}
AppPublisherURL={#MyAppURL}
AppSupportURL={#MyAppURL}
AppUpdatesURL={#MyAppURL}
DefaultDirName={autopf}\{#MyAppName}
DefaultGroupName={#MyAppName}
; Uncomment the following line to run in non administrative install mode (install for current user only).
;PrivilegesRequired=lowest
PrivilegesRequired=admin
OutputBaseFilename={#MyAppName}
Compression=none
SolidCompression=no
WizardStyle=modern dynamic
DiskSpanning=yes
DiskSliceSize=2000000000

[Registry]
;Registry data from file bf4.reg
Root: HKA; Subkey: "Software\Classes\bf4lan"; Flags: uninsdeletekeyifempty
Root: HKA; Subkey: "Software\Classes\bf4lan"; ValueType: string; ValueName: "URL Protocol"; ValueData: ""; Flags: uninsdeletevalue
Root: HKA; Subkey: "Software\Classes\bf4lan"; ValueType: string; ValueName: ""; ValueData: "URL:bf4lan Protocol"; Flags: uninsdeletevalue
Root: HKA; Subkey: "Software\Classes\bf4lan\shell"; Flags: uninsdeletekeyifempty
Root: HKA; Subkey: "Software\Classes\bf4lan\shell\open"; Flags: uninsdeletekeyifempty
Root: HKA; Subkey: "Software\Classes\bf4lan\shell\open\command"; Flags: uninsdeletekeyifempty
Root: HKA; Subkey: "Software\Classes\bf4lan\shell\open\command"; ValueType: string; ValueName: ""; ValueData: "{app}\BFUlauncher.exe %1"; Flags: uninsdeletevalue
;End of registry data from file bf4.reg

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Files]
Source: "D:\LAN Install\Battlefield 4\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs